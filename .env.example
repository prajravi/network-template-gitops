# -------------------------------------------------------------------
# Network Template GitOps -- Local credentials
# -------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# -------------------------------------------------------------------

# Catalyst Center connection
CATC_BASE_URL=https://your-catalyst-center.example.com
CATC_USERNAME=your_username
CATC_PASSWORD=your_password
# Set to 'false' to disable SSL verification (self-signed certs)
CATC_VERIFY_SSL=true

# GitHub personal access token (needs repo read access)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Optional: override the default GitHub repo API URL
# GITHUB_REPO_API=https://api.github.com/repos/prajravi/catalyst-template-library
